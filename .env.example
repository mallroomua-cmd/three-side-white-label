# Canonical public site URL — no trailing slash. Used for metadataBase, sitemap, robots.
# Local dev: match the port from `npm run dev` (this project uses 3333).
NEXT_PUBLIC_APP_URL=http://localhost:3333

# Optional — footer social icons open in a new tab when set (full URLs).
# NEXT_PUBLIC_LINK_INSTAGRAM=https://instagram.com/yourhandle
# NEXT_PUBLIC_LINK_FACEBOOK=https://facebook.com/yourpage
# NEXT_PUBLIC_LINK_YOUTUBE=https://youtube.com/@yourchannel

# Checkout: email заявок з /checkout (Resend). Без цих змінних форма все одно відправляється, але лист не йде.
# RESEND_API_KEY=re_xxxxxxxx
# CHECKOUT_NOTIFY_EMAIL=concierge@yourdomain.com
# RESEND_FROM_EMAIL=THREE SIDE <onboarding@resend.dev>
